#include<stdio.h>
int main()
{
    int a[50][50],i,j,n,sum=0;
    printf("enter order of matrix");
    scanf("%d",&n);
    for(i=0;i<n;i++)
    {
        for(j=0;j<n;j++)
        {
            printf("enter a[%d][%d]=",i,j);
            scanf("%d",&a[i][j]);
        }
    }
    printf("the formed matrix is:\n");
    for(i=0;i<n;i++)
    {
        for(j=0;j<n;j++)
        {
            printf("%d\t",a[i][j]);
        }
        printf("\n");
    }
    for(i=0;i<n;i++)
    {
        for(j=0;j<n;j++)
        {
            if(i==j||(i+j)==(n-1))
            {
                sum+=a[i][j];
            }
        }
    }
    printf("sum of all diagonal elements is:%d",sum);
    return 0;
}
