#include<stdio.h>
int fact(int n);
int main()
{
    int num,f;
    printf("enter a number");
    scanf("%d",&num);
    f=fact(num);
    printf("factorial of given number is:%d",f);
    return 0;
}
int fact(int n)
{
    if(n==1)
    {
        return 1;
    }
    else{
        return n*fact(n-1);
    }
}
