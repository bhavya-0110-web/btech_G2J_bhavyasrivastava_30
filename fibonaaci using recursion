#include<stdio.h>
int fib(int n);
int main()
{
    int n,f;
    printf("enter value of n");
    scanf("%d",&n);
    f=fib(n);
    printf("the value of %dth term in fibonacci series is %d",n,f);
    return 0;
}
int fib(int n)
{
    if(n==0||n==1)
    {
        return n;
    }
    else
    {
        return (fib(n-1)+fib(n-2));
    }
}
