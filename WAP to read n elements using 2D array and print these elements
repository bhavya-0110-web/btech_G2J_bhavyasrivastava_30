#include<stdio.h>
int main()
{
    int a[50][50],i,j,r,c;
    printf("enter number of rows and columns");
    scanf("%d%d",&r,&c);
    for(i=0;i<r;i++)
    {
        for(j=0;j<c;j++)
        {
            printf("enter a[%d][%d]=",i,j);
            scanf("%d",&a[i][j]);
        }
    }
    printf("the formed matrix is:\n");
    for(i=0;i<r;i++)
    {
        for(j=0;j<c;j++)
        {
            printf("%d\t",a[i][j]);
        }
        printf("\n");
    }
    return 0;
}
