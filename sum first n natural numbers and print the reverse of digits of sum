#include<stdio.h>
int main()
{
    int sum=0,n,i,r1,r2;
    printf("enter upto which number you want to add the numbers");
    scanf("%d",&n);
    i=0;
    while(i<=n)
    {   printf("%d\n",i);
        
        sum+=i;
        i++;
    }
    printf("sum of n numbers is:%d\n",sum);
    r1=sum%10;
    r2=sum/10;
    printf("reverse of digits of sum is:%d%d",r1,r2);
    
    
    
}
